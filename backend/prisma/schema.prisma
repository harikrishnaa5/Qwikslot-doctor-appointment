generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// JWT / API role labels (not stored on patients).
enum Role {
  USER
  DOCTOR
  ADMIN
  SUPER_ADMIN
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum SessionStatus {
  SCHEDULED
  OPEN
  PAUSED
  CLOSED
}

enum AppointmentStatus {
  BOOKED
  WAITING
  CHECKED_IN
  SKIPPED
  COMPLETED
  CANCELLED
}

/// Registered patients only.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments  Appointment[]
  refreshTokens RefreshToken[]

  @@index([phone])
}

/// Clinic staff (admin and super admin).
model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens RefreshToken[]

  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  patientId String?
  doctorId  String?
  adminId   String?

  patient User?   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor? @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  admin   Admin?  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([adminId])
  @@index([expiresAt])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]

  @@index([name])
}

/// Doctors with their own login credentials.
model Doctor {
  id             String   @id @default(cuid())
  departmentId   String
  email          String   @unique
  passwordHash   String
  name           String
  specialization String?
  experience     String?
  qualification  String?
  imageUrl       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  availabilities Availability[]
  sessions       DoctorSession[]
  appointments   Appointment[]
  refreshTokens  RefreshToken[]

  @@index([departmentId])
  @@index([active])
}

model Availability {
  id          String   @id @default(cuid())
  doctorId    String
  date        DateTime @db.Date
  startTime   String
  endTime     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, date])
}

/// One queue per doctor per calendar day (all availability blocks share it).
model DoctorSession {
  id                   String        @id @default(cuid())
  doctorId             String
  date                 DateTime      @db.Date
  label                String
  /// Span of all availability windows for this day (updated when availability changes).
  startTime            String
  endTime              String
  status               SessionStatus @default(SCHEDULED)
  /// Latest issued token number for this session.
  tokenCounter         Int           @default(0)
  /// Token number currently being served (0 = none yet).
  currentToken         Int           @default(0)
  avgMinutesPerPatient Int           @default(8)
  openedAt             DateTime?
  closedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([doctorId, date])
  @@index([doctorId, date, status])
}

model Appointment {
  id             String            @id @default(cuid())
  doctorId       String
  sessionId      String?
  userId         String
  scheduledAt    DateTime
  date           DateTime          @db.Date
  tokenNumber    Int
  status         AppointmentStatus @default(BOOKED)
  paymentRef     String?
  notes          String?
  scheduleNotice String?
  checkedInAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  doctor  Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session DoctorSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, tokenNumber])
  @@unique([doctorId, scheduledAt])
  @@index([sessionId, status, tokenNumber])
  @@index([doctorId, date, status])
  @@index([userId, scheduledAt])
}
