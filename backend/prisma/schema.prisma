generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SessionStatus {
  SCHEDULED
  OPEN
  PAUSED
  CLOSED
}

enum AppointmentStatus {
  WAITING
  CHECKED_IN
  IN_PROGRESS
  SKIPPED
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctorProfile  Doctor?
  appointments   Appointment[]
  refreshTokens  RefreshToken[]

  @@index([role])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]

  @@index([name])
}

model Doctor {
  id             String   @id @default(cuid())
  departmentId   String
  name           String
  specialization String?
  experience     String?
  qualification  String?
  imageUrl       String?
  userId         String?  @unique
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department     Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  availabilities Availability[]
  sessions       DoctorSession[]
  appointments   Appointment[]

  @@index([departmentId])
  @@index([active])
}

model Availability {
  id          String   @id @default(cuid())
  doctorId    String
  date        DateTime @db.Date
  startTime   String
  endTime     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor  Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session DoctorSession?

  @@index([doctorId, date])
}

/// Independent queue per doctor per day/session (e.g. morning vs evening).
model DoctorSession {
  id                   String        @id @default(cuid())
  doctorId             String
  availabilityId       String?       @unique
  date                 DateTime      @db.Date
  label                String
  startTime            String
  endTime              String
  status               SessionStatus @default(SCHEDULED)
  /// Latest issued token number for this session.
  tokenCounter         Int           @default(0)
  /// Token number currently being served (0 = none yet).
  currentToken         Int           @default(0)
  avgMinutesPerPatient Int           @default(8)
  openedAt             DateTime?
  closedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  availability Availability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@unique([doctorId, date, startTime, endTime])
  @@index([doctorId, date, status])
  @@index([doctorId, date])
}

model Appointment {
  id             String            @id @default(cuid())
  doctorId       String
  sessionId      String?
  userId         String
  scheduledAt    DateTime
  date           DateTime          @db.Date
  tokenNumber    Int
  status         AppointmentStatus @default(WAITING)
  paymentRef     String?
  notes          String?
  scheduleNotice String?
  checkedInAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  doctor  Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session DoctorSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, tokenNumber])
  @@unique([doctorId, scheduledAt])
  @@index([sessionId, status, tokenNumber])
  @@index([doctorId, date, status])
  @@index([userId, scheduledAt])
}
