NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doctor_appointment?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret"
# Access token JWT expires in 12h (configured in code). Refresh token TTL:
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGIN="http://localhost:5173"

# Doctor profile photos: S3 or LocalStack (optional; required for POST /api/v1/admin/uploads/doctor-photo)
# docker compose -f docker-compose.localstack.yml up -d
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=qwikslot-media
S3_PUBLIC_BASE_URL=http://localhost:4566/qwikslot-media
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
# LocalStack: makes objects readable in the browser without signed URLs
S3_OBJECT_ACL=public-read
